{
  "name": "makespdf-vscode-plugin",
  "displayName": "Markdown to PDF",
  "description": "Convert Markdown files to PDF using the makesPDF service",
  "version": "0.0.1",
  "publisher": "makesPDF",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "makespdf.convertMarkdownToPdf",
        "title": "Convert Markdown to PDF",
        "icon": "$(file-pdf)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "makespdf.convertMarkdownToPdf",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "makespdf.convertMarkdownToPdf",
          "when": "resourceLangId == markdown"
        }
      ]
    },
    "configuration": {
      "title": "Markdown to PDF",
      "properties": {
        "makespdf.serviceUrl": {
          "type": "string",
          "default": "https://makespdf.com",
          "description": "URL of the PDF service"
        },
        "makespdf.apiToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "API token for the PDF service. Sent as `Authorization: Bearer <token>`. Get one from your account on [makespdf.com](https://makespdf.com)."
        },
        "makespdf.pageSize": {
          "type": "string",
          "enum": [
            "A3",
            "A4",
            "A5",
            "Letter",
            "Legal"
          ],
          "default": "A4",
          "description": "Page size for generated PDFs"
        },
        "makespdf.fontFamily": {
          "type": "string",
          "enum": [
            "Inter",
            "NotoSans"
          ],
          "default": "Inter",
          "description": "Font family for generated PDFs"
        },
        "makespdf.fontSize": {
          "type": "number",
          "default": 10,
          "minimum": 6,
          "maximum": 24,
          "description": "Font size in points"
        },
        "makespdf.margins": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "default": [
            40,
            40,
            40,
            40
          ],
          "minItems": 4,
          "maxItems": 4,
          "description": "Page margins in points [top, right, bottom, left]"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch=forever",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2"
  }
}
