{
  "name": "makespdf-vscode-plugin",
  "displayName": "makesPDF — Markdown to PDF",
  "description": "Convert Markdown files to PDF using the makesPDF.com service",
  "version": "0.0.4",
  "publisher": "Lecstor",
  "repository": {
    "type": "git",
    "url": "https://github.com/makesPDF/makespdf-vscode-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/makesPDF/makespdf-vscode-plugin/issues"
  },
  "homepage": "https://github.com/makesPDF/makespdf-vscode-plugin#readme",
  "license": "MIT",
  "icon": "images/logo-icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "makespdf.convertMarkdownToPdf",
        "title": "makesPDF from markdown",
        "icon": "$(file-pdf)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "makespdf.convertMarkdownToPdf",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "makespdf.convertMarkdownToPdf",
          "when": "resourceLangId == markdown"
        }
      ]
    },
    "configuration": {
      "title": "makesPDF",
      "properties": {
        "makespdf.serviceUrl": {
          "type": "string",
          "default": "https://makespdf.com",
          "description": "URL of the PDF service"
        },
        "makespdf.apiToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "API token for the PDF service. Sent as `Authorization: Bearer <token>`. Get one from [your API keys page on makespdf.com](https://makespdf.com/settings/api-keys)."
        },
        "makespdf.pageSize": {
          "type": "string",
          "enum": [
            "A3",
            "A4",
            "A5",
            "Letter",
            "Legal"
          ],
          "default": "A4",
          "description": "Page size for generated PDFs"
        },
        "makespdf.fontFamily": {
          "type": "string",
          "enum": [
            "Inter",
            "NotoSans"
          ],
          "default": "Inter",
          "description": "Font family for generated PDFs"
        },
        "makespdf.fontSize": {
          "type": "number",
          "default": 10,
          "minimum": 6,
          "maximum": 24,
          "description": "Font size in points"
        },
        "makespdf.margins": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "default": [
            40,
            40,
            40,
            40
          ],
          "minItems": 4,
          "maxItems": 4,
          "description": "Page margins in points [top, right, bottom, left]"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch=forever",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "npm run build",
    "login": "vsce login Lecstor",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "publish:patch": "vsce publish patch --no-dependencies",
    "publish:minor": "vsce publish minor --no-dependencies",
    "publish:major": "vsce publish major --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2"
  }
}
